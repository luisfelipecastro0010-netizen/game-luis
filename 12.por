programa {
  funcao inicio() {
    real distancia, litros, consumo
    escreva("digite a distacia percorrido (km): ")
    leia(distancia)
    escreva("digite o combustivel litros gasto (litros): ")
    leia(litros)
    consumo = distancia / litros
    escreva("o consumo medio e: ", consumo, "km/1")
  }
}
